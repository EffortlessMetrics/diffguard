      "match_mode": "any",
      "multiline": false,
      "context_patterns": [],
      "escalate_patterns": [],
      "depends_on": [],
      "help": "Use a proper logging library (e.g., winston, pino, bunyan) instead of console.log. For client-side code, consider using a logger that can be disabled in production builds.",
      "url": "https://developer.mozilla.org/en-US/docs/Web/API/console",
      "tags": ["debug"],
      "test_cases": []
    },
