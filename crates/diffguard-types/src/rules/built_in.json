{
  "includes": [],
  "defaults": {
    "base": "origin/main",
    "head": "HEAD",
    "scope": "added",
    "fail_on": "error",
    "max_findings": 200,
    "diff_context": 0
  },
  "rule": [
    {
      "id": "rust.no_unwrap",
      "severity": "error",
      "message": "Avoid unwrap/expect in production code.",
      "description": "",
      "languages": ["rust"],
      "patterns": ["\\.unwrap\\(", "\\.expect\\("],
      "paths": ["**/*.rs"],
      "exclude_paths": ["**/tests/**", "**/benches/**", "**/examples/**"],
      "ignore_comments": true,
      "ignore_strings": true,
      "match_mode": "any",
      "multiline": false,
      "context_patterns": [],
      "escalate_patterns": [],
      "depends_on": [],
      "help": "Use the ? operator to propagate errors, or use expect() with a meaningful message that explains the invariant. Consider using anyhow or thiserror for structured error handling.",
      "url": "https://doc.rust-lang.org/book/ch09-02-recoverable-errors-with-result.html",
      "tags": ["safety"],
      "test_cases": []
    },
    {
      "id": "rust.no_dbg",
      "severity": "warn",
      "message": "Remove dbg!/println! before merging.",
      "description": "",
      "languages": ["rust"],
      "patterns": ["\\bdbg!\\(", "\\bprintln!\\(", "\\beprintln!\\("],
      "paths": ["**/*.rs"],
      "exclude_paths": ["**/tests/**", "**/benches/**", "**/examples/**"],
      "ignore_comments": true,
      "ignore_strings": true,
      "match_mode": "any",
      "multiline": false,
      "context_patterns": [],
      "escalate_patterns": [],
      "depends_on": [],
      "help": "Remove debug output before merging. For logging, use the log or tracing crate instead. If you need to keep the output, consider using conditional compilation with #[cfg(debug_assertions)].",
      "url": "https://doc.rust-lang.org/std/macro.dbg.html",
      "tags": ["debug"],
      "test_cases": []
    },
    {
      "id": "rust.no_todo",
      "severity": "warn",
      "message": "Resolve TODO/FIXME comments before merging.",
      "description": "",
      "languages": ["rust"],
      "patterns": ["\\bTODO\\b", "\\bFIXME\\b", "\\btodo!\\s*\\(", "\\bunimplemented!\\s*\\("],
      "paths": ["**/*.rs"],
      "exclude_paths": [],
      "ignore_comments": false,
      "ignore_strings": true,
      "match_mode": "any",
      "multiline": false,
      "context_patterns": [],
      "escalate_patterns": [],
      "depends_on": [],
      "help": "Address TODO/FIXME comments before merging, or create tracking issues for planned work. The todo! and unimplemented! macros will panic at runtime.",
      "url": null,
      "tags": ["style"],
      "test_cases": []
    },
    {
      "id": "python.no_print",
      "severity": "warn",
      "message": "Remove print() before merging.",
      "description": "",
      "languages": ["python"],
      "patterns": ["\\bprint\\s*\\("],
      "paths": ["**/*.py"],
      "exclude_paths": ["**/tests/**", "**/test_*.py"],
      "ignore_comments": true,
      "ignore_strings": true,
      "match_mode": "any",
      "multiline": false,
      "context_patterns": [],
      "escalate_patterns": [],
      "depends_on": [],
      "help": "Use the logging module instead of print() for production code. Configure logging levels appropriately (DEBUG, INFO, WARNING, ERROR).",
      "url": "https://docs.python.org/3/library/logging.html",
      "tags": ["debug"],
      "test_cases": []
    },
    {
      "id": "python.no_pdb",
      "severity": "error",
      "message": "Remove debugger statements before merging.",
      "description": "",
      "languages": ["python"],
      "patterns": ["\\bimport\\s+pdb\\b", "\\bpdb\\.set_trace\\s*\\("],
      "paths": ["**/*.py"],
      "exclude_paths": [],
      "ignore_comments": true,
      "ignore_strings": true,
      "match_mode": "any",
      "multiline": false,
      "context_patterns": [],
      "escalate_patterns": [],
      "depends_on": [],
      "help": "Remove pdb debugger statements before merging. These will cause the application to pause and wait for interactive input in production.",
      "url": "https://docs.python.org/3/library/pdb.html",
      "tags": ["debug"],
      "test_cases": []
    },
    {
      "id": "python.no_breakpoint",
      "severity": "error",
      "message": "Remove breakpoint() calls before merging.",
      "description": "",
      "languages": ["python"],
      "patterns": ["\\bbreakpoint\\s*\\("],
      "paths": ["**/*.py"],
      "exclude_paths": [],
      "ignore_comments": true,
      "ignore_strings": true,
      "match_mode": "any",
      "multiline": false,
      "context_patterns": [],
      "escalate_patterns": [],
      "depends_on": [],
      "help": "Remove breakpoint() calls before merging. The breakpoint() function (Python 3.7+) invokes the debugger and will pause execution in production.",
      "url": "https://docs.python.org/3/library/functions.html#breakpoint",
      "tags": ["debug"],
      "test_cases": []
    },
    {
      "id": "js.no_console",
      "severity": "warn",
      "message": "Remove console.log before merging.",
